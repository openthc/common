{
	"name": "openthc/common",
	"description": "OpenTHC Common Library",
	"license": "GPL-3.0-only",
	"autoload": {
		"files": [
			"lib/err.php",
			"lib/php.php",
			"lib/stat.php"
		],
		"psr-4": {
			"OpenTHC\\": "./lib",
			"OpenTHC\\Test\\": "./test"
		}
	},
	"require": {
		"php": ">=7.3.0",
		"ext-curl": "*",
		"ext-date": "*",
		"ext-json": "*",
		"ext-session": "*",
		"ext-sockets": "*",
		"ext-PDO": "*",
		"docopt/docopt": "1.0.6",
		"edoceo/lowline": "dev-master",
		"edoceo/radix": "dev-main",
		"geoip2/geoip2": "3.3.0",
		"firebase/php-jwt": "6.4.0",
		"giggsey/libphonenumber-for-php": "9.0.23",
		"guzzlehttp/guzzle": "7.9.2",
		"league/commonmark": "2.8.0",
		"league/oauth2-client": "2.9.0",
		"slim/slim": "4.15.1",
		"swaggest/json-schema": "0.12.43"
	},
	"require-dev": {
		"php-webdriver/webdriver": "1.16.0",
		"phpmd/phpmd": "2.15.0",
		"phpstan/phpstan": "2.1.38",
		"phpunit/phpunit": "12.5.8"
	}
}
